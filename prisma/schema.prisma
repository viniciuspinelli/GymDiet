// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  workoutSessions WorkoutSession[]
}

// ========================
// WORKOUT MODULE
// ========================

model WorkoutPlan {
  id          Int        @id @default(autoincrement())
  name        String     // e.g. "Peito + Bíceps", "Costas + Tríceps"
  description String?
  dayOfWeek   String?    // e.g. "Segunda", "Quarta"
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  exercises   Exercise[]
  sessions    WorkoutSession[]
  createdAt   DateTime   @default(now())
}

model Exercise {
  id            Int         @id @default(autoincrement())
  workoutPlanId Int
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  name          String      // e.g. "Supino Reto"
  sets          Int         // e.g. 4
  reps          String      // e.g. "12" or "8-12" or "até falha"
  weight        String?     // e.g. "60kg" or "peso corporal"
  restSeconds   Int?        // rest between sets in seconds
  notes         String?     // technique tips
  order         Int         @default(0)
  sessionExercises SessionExercise[]
}

model WorkoutSession {
  id            Int       @id @default(autoincrement())
  userId        Int
  user          User      @relation(fields: [userId], references: [id])
  workoutPlanId Int
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id])
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  isCompleted   Boolean   @default(false)
  durationMin   Int?      // total duration in minutes
  notes         String?
  sessionExercises SessionExercise[]
}

model SessionExercise {
  id               Int            @id @default(autoincrement())
  workoutSessionId Int
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exerciseId       Int
  exercise         Exercise       @relation(fields: [exerciseId], references: [id])
  isCompleted      Boolean        @default(false)
  completedAt      DateTime?
  actualSets       Int?
  actualReps       String?
  actualWeight     String?
  notes            String?
}

// ========================
// DIET MODULE
// ========================

model MealPlan {
  id        Int    @id @default(autoincrement())
  name      String // e.g. "Plano Cutting", "Plano Manutenção"
  isActive  Boolean @default(false)
  meals     Meal[]
  createdAt DateTime @default(now())
}

model Meal {
  id         Int      @id @default(autoincrement())
  mealPlanId Int
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  name       String   // e.g. "Café da Manhã", "Almoço", "Pré-Treino", "Pós-Treino"
  time       String?  // e.g. "07:00"
  order      Int      @default(0)
  foods      MealFood[]
}

model MealFood {
  id       Int    @id @default(autoincrement())
  mealId   Int
  meal     Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  name     String // e.g. "Frango grelhado"
  quantity String // e.g. "200g", "3 ovos", "1 xícara"
  calories Int?
  protein  Float? // grams
  carbs    Float? // grams
  fat      Float? // grams
  notes    String?
  order    Int    @default(0)
}

// ========================
// SHOPPING LIST MODULE
// ========================

model ShoppingList {
  id        Int            @id @default(autoincrement())
  name      String         @default("Lista de Compras")
  createdAt DateTime       @default(now())
  items     ShoppingItem[]
}

model ShoppingItem {
  id             Int          @id @default(autoincrement())
  shoppingListId Int
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  name           String
  quantity       String?
  category       String?      // e.g. "Proteínas", "Carboidratos", "Vegetais", "Laticínios"
  isChecked      Boolean      @default(false)
  notes          String?
  order          Int          @default(0)
}
