# Production Environment Variables
# These are automatically set by Render, but you can override if needed

# Database (auto-generated by Render from managed database)
# DATABASE_URL is automatically injected by Render

# Session Secret (auto-generated by Render)
# SESSION_SECRET is automatically generated

# Node Environment
NODE_ENV=production

# Server Port (Render listens on 0.0.0.0:3000 by default)
PORT=3000

# Optional: Add your custom production settings below
# LOG_LEVEL=info
