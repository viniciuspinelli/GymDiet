# NPM configuration for production builds
# This file optimizes npm ci for Render deployment

# Use exact versions from package-lock.json
engine-strict=true

# Disable scripts during ci (faster builds)
scripts-prepend-node-path=auto

# Use production registry
registry=https://registry.npmjs.org/

# Audit and funding disabled in CI
audit=false
fund=false

# Log level
loglevel=warn
