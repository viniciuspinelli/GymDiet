<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - GymDiet</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#FF6B00">
    <% if (typeof csrfToken !== 'undefined') { %>
        <meta name="csrf-token" content="<%= csrfToken %>">
    <% } %>
</head>
<body>
    <div class="app-container">
        <!-- Header -->
        <% if (user) { %>
        <header class="app-header">
            <div class="header-content">
                <div class="logo">
                    <a href="/workouts" class="logo-link">
                        <span class="logo-icon">⚡</span>
                        <span class="logo-text">GymDiet</span>
                    </a>
                </div>
                <div class="header-actions">
                    <% if (user) { %>
                        <div class="user-badge">
                            <span class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></span>
                            <span class="user-name"><%= user.username %></span>
                        </div>
                        <a href="/auth/logout" class="btn-logout">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                            Sair
                        </a>
                    <% } %>
                </div>
            </div>
        </header>
        <% } %>

        <div class="main-wrapper">
            <!-- Sidebar Navigation (Desktop) -->
            <% if (user) { %>
                <nav class="sidebar-nav">
                    <div class="sidebar-section">
                        <span class="sidebar-label">TREINOS</span>
                        <ul>
                            <li><a href="/workouts" class="nav-link <%= title === 'Treinos' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
                                Meus Treinos
                            </a></li>
                            <li><a href="/workouts/plans" class="nav-link <%= title === 'Gerenciar Treinos' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                                Gerenciar Planos
                            </a></li>
                            <li><a href="/workouts/history" class="nav-link <%= title === 'Histórico de Treinos' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                                Histórico
                            </a></li>
                        </ul>
                    </div>
                    <div class="sidebar-section">
                        <span class="sidebar-label">NUTRIÇÃO</span>
                        <ul>
                            <li><a href="/diet" class="nav-link <%= title === 'Dieta' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10"/></svg>
                                Minha Dieta
                            </a></li>
                            <li><a href="/shopping" class="nav-link <%= title === 'Lista de Compras' ? 'active' : '' %>">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                                Lista de Compras
                            </a></li>
                        </ul>
                    </div>
                </nav>
            <% } %>

            <!-- Main Content -->
            <main class="main-content">
                <%- body %>
            </main>
        </div>

        <!-- Bottom Navigation (Mobile) -->
        <% if (user) { %>
            <nav class="bottom-nav">
                <a href="/workouts" class="nav-tab <%= title === 'Treinos' ? 'active' : '' %>">
                    <span>🏋️</span>
                    <span>Treinos</span>
                </a>
                <a href="/diet" class="nav-tab <%= title === 'Dieta' ? 'active' : '' %>">
                    <span>🥗</span>
                    <span>Dieta</span>
                </a>
                <a href="/shopping" class="nav-tab <%= title === 'Lista de Compras' ? 'active' : '' %>">
                    <span>🛒</span>
                    <span>Compras</span>
                </a>
                <a href="/workouts/plans" class="nav-tab <%= title === 'Gerenciar Treinos' ? 'active' : '' %>">
                    <span>📋</span>
                    <span>Planos</span>
                </a>
                <a href="/workouts/history" class="nav-tab <%= title === 'Histórico de Treinos' ? 'active' : '' %>">
                    <span>📊</span>
                    <span>Histórico</span>
                </a>
            </nav>
        <% } %>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast"></div>

    <!-- Modal -->
    <div id="modal" class="modal">
        <div class="modal-content">
            <span class="modal-close">&times;</span>
            <h2 id="modalTitle">Confirmação</h2>
            <p id="modalMessage"></p>
            <div class="modal-actions">
                <button id="modalCancel" class="btn btn-secondary">Cancelar</button>
                <button id="modalConfirm" class="btn btn-danger">Confirmar</button>
            </div>
        </div>
    </div>

    <script src="/js/utils.js"></script>
    <script src="/js/theme.js"></script>
    <script src="/js/workout.js"></script>
    <script src="/js/shopping.js"></script>
</body>
</html>
