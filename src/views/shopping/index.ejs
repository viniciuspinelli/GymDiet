<div class="shopping-page">
    <!-- Shopping List Header -->
    <div class="shopping-header">
        <h1>🛒 Lista de Compras</h1>
        <div class="shopping-actions">
            <button class="btn btn-secondary" onclick="importFromDiet()">
                📥 Importar da Dieta
            </button>
            <button class="btn btn-secondary" onclick="clearChecked()">
                🗑️ Limpar Marcados
            </button>
            <button class="btn btn-secondary" onclick="newList()">
                📋 Nova Lista
            </button>
        </div>
    </div>

    <!-- Progress Bar -->
    <div class="progress-container">
        <div class="progress-label">
            <span id="progress"><%= checkedItems %> de <%= totalItems %> itens comprados</span>
        </div>
        <div class="progress-bar">
            <div id="progressFill" class="progress-fill" style="width: <%= totalItems > 0 ? (checkedItems / totalItems * 100) : 0 %>%"></div>
        </div>
    </div>

    <!-- Shopping Items by Category -->
    <% Object.entries(itemsByCategory).forEach(([category, items]) => { %>
        <div class="category-section">
            <h2 class="category-title">
                <%= category %>
                <span class="category-count">(<%= items.length %>)</span>
            </h2>

            <div class="items-list">
                <% items.forEach(item => { %>
                    <div class="shopping-item <%= item.isChecked ? 'checked' : '' %>" data-item-id="<%= item.id %>">
                        <input type="checkbox" class="item-checkbox" <%= item.isChecked ? 'checked' : '' %>
                               onchange="toggleItem(<%= item.id %>)">
                        
                        <div class="item-content">
                            <span class="item-name"><%= item.name %></span>
                            <% if (item.quantity) { %>
                                <span class="item-quantity"><%= item.quantity %></span>
                            <% } %>
                            <% if (item.notes) { %>
                                <span class="item-notes"><%= item.notes %></span>
                            <% } %>
                        </div>

                        <button class="btn-delete" onclick="deleteItem(<%= item.id %>)">
                            ✕
                        </button>
                    </div>
                <% }); %>
            </div>
        </div>
    <% }); %>

    <!-- Add Item Form -->
    <div class="add-item-section">
        <h2>Adicionar Item</h2>
        <form onsubmit="addItem(event)">
            <input type="text" placeholder="Nome do item" required id="itemName">
            <input type="text" placeholder="Quantidade" id="itemQuantity">
            <select id="itemCategory">
                <option value="Proteínas">Proteínas</option>
                <option value="Carboidratos">Carboidratos</option>
                <option value="Vegetais">Vegetais</option>
                <option value="Laticínios">Laticínios</option>
                <option value="Frutas">Frutas</option>
                <option value="Outros">Outros</option>
            </select>
            <button type="submit" class="btn btn-primary">+ Adicionar</button>
        </form>
    </div>
</div>

<script>
    const listId = '<%= list.id %>';

    function toggleItem(itemId) {
        fetch(`/shopping/items/${itemId}/toggle`, {
            method: 'PATCH'
        }).then(res => res.json()).then(data => {
            if (data.success) {
                updateProgress();
            }
        });
    }

    function deleteItem(itemId) {
        if (confirm('Tem certeza?')) {
            fetch(`/shopping/items/${itemId}`, {
                method: 'DELETE'
            }).then(() => {
                document.querySelector(`[data-item-id="${itemId}"]`).remove();
                updateProgress();
            });
        }
    }

    function addItem(event) {
        event.preventDefault();
        const name = document.getElementById('itemName').value;
        const quantity = document.getElementById('itemQuantity').value;
        const category = document.getElementById('itemCategory').value;

        fetch(`/shopping/lists/${listId}/items`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ shoppingListId: listId, name, quantity, category })
        }).then(() => location.reload());
    }

    function clearChecked() {
        if (confirm('Limpar todos os itens marcados?')) {
            fetch(`/shopping/lists/${listId}/checked`, {
                method: 'DELETE'
            }).then(() => location.reload());
        }
    }

    function importFromDiet() {
        fetch('/shopping/import-from-diet', {
            method: 'POST'
        }).then(res => res.json()).then(data => {
            if (data.success) {
                showToast(`${data.count} itens importados! ✅`, 'success');
                setTimeout(() => location.reload(), 1000);
            }
        }).catch(err => showToast('Erro ao importar', 'error'));
    }

    function newList() {
        fetch('/shopping/lists', {
            method: 'POST'
        }).then(() => location.reload());
    }

    function updateProgress() {
        const checked = document.querySelectorAll('.shopping-item.checked').length;
        const total = document.querySelectorAll('.shopping-item').length;
        document.getElementById('progress').textContent = `${checked} de ${total} itens comprados`;
        document.getElementById('progressFill').style.width = `${total > 0 ? (checked / total * 100) : 0}%`;
    }
</script>
