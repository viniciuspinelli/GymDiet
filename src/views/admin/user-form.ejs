<div class="admin-page">
    <div class="page-header">
        <div>
            <a href="/admin/users" class="btn-back">← Voltar</a>
            <h1><%= editUser ? '✏️ Editar Usuário' : '➕ Novo Aluno' %></h1>
        </div>
    </div>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="admin-form-card">
        <form method="POST" action="/admin/users/<%= editUser ? editUser.id + '/edit' : 'new' %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="form-field">
                <label for="username">Nome de usuário</label>
                <input type="text" id="username" name="username"
                    value="<%= editUser ? editUser.username : '' %>"
                    placeholder="ex: joao" required>
            </div>

            <div class="form-field">
                <label for="fullName">Nome completo</label>
                <input type="text" id="fullName" name="fullName"
                    value="<%= editUser ? (editUser.fullName || '') : '' %>"
                    placeholder="ex: João da Silva">
            </div>

            <div class="form-field">
                <label for="email">E-mail <span class="field-hint">(para recuperação de senha)</span></label>
                <input type="email" id="email" name="email"
                    value="<%= editUser ? (editUser.email || '') : '' %>"
                    placeholder="aluno@email.com" required>
            </div>

            <div class="form-field">
                <label for="password">
                    Senha <%= editUser ? '<span class="field-hint">(deixe em branco para não alterar)</span>' : '' %>
                </label>
                <input type="password" id="password" name="password"
                    placeholder="••••••••"
                    <%= editUser ? '' : 'required' %>>
            </div>

            <div class="form-field">
                <label for="role">Nível de acesso</label>
                <select id="role" name="role">
                    <option value="user" <%= !editUser || editUser.role === 'user' ? 'selected' : '' %>>👤 Aluno</option>
                    <% if (isAdmin) { %>
                    <option value="instructor" <%= editUser && editUser.role === 'instructor' ? 'selected' : '' %>>🎓 Instrutor</option>
                    <option value="admin" <%= editUser && editUser.role === 'admin' ? 'selected' : '' %>>⚡ Admin</option>
                    <% } %>
                </select>
            </div>

            <% if (isAdmin && instructors && instructors.length > 0) { %>
            <div class="form-field">
                <label for="instructorId">Instrutor responsável <span class="field-hint">(opcional)</span></label>
                <select id="instructorId" name="instructorId">
                    <option value="">-- Nenhum --</option>
                    <% instructors.forEach(function(inst) { %>
                    <option value="<%= inst.id %>" <%= editUser && editUser.instructorId === inst.id ? 'selected' : '' %>>
                        <%= inst.fullName || inst.username %>
                    </option>
                    <% }); %>
                </select>
            </div>
            <% } %>

            <div class="form-actions">
                <a href="/admin/users" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    <%= editUser ? 'Salvar Alterações' : 'Criar Aluno' %>
                </button>
            </div>
        </form>
    </div>
</div>
