<div class="diet-page">
    <!-- Header -->
    <div class="page-header">
        <h1>🍽️ Plano de Dieta</h1>
    </div>

    <!-- Plan Selector -->
    <div class="plan-selector-section">
        <label for="planSelect">Plano Ativo:</label>
        <div class="selector-row">
            <select id="planSelect" onchange="switchPlan(this.value)">
                <option value="">Selecione um plano...</option>
                <% allPlans.forEach(plan => { %>
                    <option value="<%= plan.id %>" data-template="<%= plan.isTemplate ? '1' : '0' %>" <%= (activePlan && plan.id === activePlan.id) ? 'selected' : '' %>>
                        <%= plan.name %> <%= plan.isTemplate ? '📚' : (plan.isActive ? '(Ativo)' : '') %>
                    </option>
                <% }); %>
            </select>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
            <button class="btn btn-success" onclick="createNewPlan()">➕ Novo Plano</button>
            <% } %>
            <% if (typeof isAdmin !== 'undefined' && isAdmin && activePlan && activePlan.id) { %>
            <button class="btn btn-secondary btn-sm" id="btn-toggle-template" 
                    onclick="toggleDietTemplate(<%= activePlan.id %>, this)"
                    title="<%= activePlan.isTemplate ? 'Remover da Biblioteca' : 'Mover para Biblioteca' %>">
                <%= activePlan.isTemplate ? '📚 Na Biblioteca' : '📋 Tornar Template' %>
            </button>
            <% } %>
        </div>
    </div>

    <% if (activePlan && activePlan.id) { %>
        <!-- Daily Totals -->
        <div class="totals-card">
            <h2>📊 Resumo Nutricional</h2>
            <div class="totals-grid">
                <div class="total-item">
                    <span class="label">Calorias</span>
                    <span class="value"><%= totals.totalCalories %> kcal</span>
                </div>
                <div class="total-item">
                    <span class="label">Proteína</span>
                    <span class="value"><%= totals.totalProtein.toFixed(1) %>g</span>
                </div>
                <div class="total-item">
                    <span class="label">Carboidratos</span>
                    <span class="value"><%= totals.totalCarbs.toFixed(1) %>g</span>
                </div>
                <div class="total-item">
                    <span class="label">Gordura</span>
                    <span class="value"><%= totals.totalFat.toFixed(1) %>g</span>
                </div>
            </div>
        </div>

        <!-- Add Meal Button -->
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <div class="add-meal-section">
            <button class="btn btn-primary btn-lg" onclick="showAddMealForm()">
                ➕ Adicionar Refeição
            </button>
        </div>

        <!-- Add Meal Form (Hidden by default) -->
        <div class="add-meal-form" id="addMealForm" style="display: none;">
            <h3>Adicionar Nova Refeição</h3>
            <form onsubmit="submitAddMeal(event)">
                <div class="form-row">
                    <div class="form-group flex-1">
                        <label>Nome da Refeição *</label>
                        <input type="text" id="mealName" placeholder="ex: Café da Manhã, Almoço, Lanche..." required>
                    </div>
                    <div class="form-group">
                        <label>Horário</label>
                        <input type="time" id="mealTime" placeholder="HH:MM">
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-success">✓ Criar Refeição</button>
                    <button type="button" class="btn btn-secondary" onclick="hideAddMealForm()">✕ Cancelar</button>
                </div>
            </form>
        </div>
        <% } %>

        <!-- Meals -->
        <div class="meals-container">
            <% if (activePlan.meals && activePlan.meals.length > 0) { %>
                <% activePlan.meals.forEach((meal, mealIndex) => { %>
                    <div class="meal-card">
                        <div class="meal-header">
                            <div class="meal-title">
                                <h3><%= meal.name %></h3>
                                <% if (meal.time) { %>
                                    <span class="meal-time">🕐 <%= meal.time %></span>
                                <% } %>
                            </div>
                            <div class="meal-header-actions">
                                <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                                <button class="btn btn-success btn-sm" onclick="toggleAddFoodForm(<%= meal.id %>)">➕ Alimento</button>
                                <button class="btn-delete btn" onclick="deleteMeal(<%= meal.id %>)" title="Deletar refeição">🗑️</button>
                                <% } %>
                            </div>
                        </div>

                        <div class="foods-section">
                            <% if (meal.foods && meal.foods.length > 0) { %>
                                <table class="foods-table">
                                    <thead>
                                        <tr>
                                            <th>Alimento</th>
                                            <th>Quantidade</th>
                                            <th>Calorias</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% meal.foods.forEach(food => { %>
                                            <tr data-food-id="<%= food.id %>" data-calories="<%= food.calories || 0 %>" data-protein="<%= food.protein || 0 %>" data-carbs="<%= food.carbs || 0 %>" data-fat="<%= food.fat || 0 %>">
                                                <td>
                                                    <strong><%= food.name %></strong>
                                                    <% if (food.notes) { %>
                                                        <br><small class="food-notes"><%= food.notes %></small>
                                                    <% } %>
                                                </td>
                                                <td class="quantity-cell"><%= food.quantity %></td>
                                                <td><%= food.calories ? food.calories + ' kcal' : '—' %></td>
                                                <td><% if (typeof isAdmin !== 'undefined' && isAdmin) { %><button class="btn btn-delete btn-sm" onclick="deleteFood(<%= food.id %>)">🗑️</button><% } %></td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            <% } else { %>
                                <p class="no-foods">Nenhum alimento adicionado a esta refeição</p>
                            <% } %>
                        </div>

                        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                        <div class="add-food-form" id="addFoodForm-<%= meal.id %>" style="display: none;">
                            <h4>➕ Adicionar Alimento</h4>
                            <form onsubmit="addFood(event, <%= meal.id %>)">
                                <div class="form-row">
                                    <div class="form-group flex-2">
                                        <label>Nome * <span class="food-search-hint">🔍 busca automática</span></label>
                                        <div class="food-search-wrapper">
                                            <input type="text" class="food-name" placeholder="ex: Frango grelhado" required maxlength="100" autocomplete="off" oninput="onFoodNameInput(this)">
                                            <div class="food-autocomplete-dropdown" style="display:none;"></div>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label>Qtd</label>
                                        <input type="text" class="food-quantity" placeholder="150" oninput="onQuantityInput(this)">
                                    </div>
                                    <div class="form-group">
                                        <label>Unidade</label>
                                        <select class="food-unit" onchange="onUnitChange(this)">
                                            <option value="g">g</option>
                                            <option value="ml">ml</option>
                                            <option value="un">un</option>
                                            <option value=" porção"> porção</option>
                                            <option value="">outro</option>
                                        </select>
                                        <small class="unit-hint" style="display:none;color:#888;font-size:11px;">valores por 100g — ajuste manualmente</small>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Calorias (kcal)</label>
                                        <input type="number" class="food-calories" placeholder="0" min="0" step="0.01">
                                    </div>
                                    <div class="form-group">
                                        <label>Proteína (g)</label>
                                        <input type="number" class="food-protein" placeholder="0" min="0" step="0.1">
                                    </div>
                                    <div class="form-group">
                                        <label>Carbs (g)</label>
                                        <input type="number" class="food-carbs" placeholder="0" min="0" step="0.1">
                                    </div>
                                    <div class="form-group">
                                        <label>Gordura (g)</label>
                                        <input type="number" class="food-fat" placeholder="0" min="0" step="0.1">
                                    </div>
                                </div>
                                <div class="form-group" style="margin-bottom: 15px;">
                                    <label>Notas (opcional)</label>
                                    <input type="text" class="food-notes-input" placeholder="ex: Sem pele, cozido...">
                                </div>
                                <div class="form-actions">
                                    <button type="submit" class="btn btn-success btn-sm">✓ Adicionar</button>
                                    <button type="button" class="btn btn-secondary btn-sm" onclick="toggleAddFoodForm(<%= meal.id %>)">✕ Cancelar</button>
                                </div>
                            </form>
                        </div>
                        <% } %>

                    </div>
                <% }); %>
            <% } else { %>
                <div class="empty-state">
                    <p>Nenhuma refeição adicionada ainda ao plano "<%= activePlan.name %>"</p>
                    <p>Use o botão acima para criar uma nova refeição! 👆</p>
                </div>
            <% } %>
        </div>

    <% } else { %>
        <div class="empty-state">
            <p>Nenhum plano de dieta selecionado</p>
            <button class="btn btn-primary btn-lg" onclick="createNewPlan()">Criar Plano de Dieta</button>
        </div>
    <% } %>
</div>

