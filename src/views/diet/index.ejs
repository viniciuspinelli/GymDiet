<script>
    const csrfToken = '<%= csrfToken %>';
    const activePlanId = '<%= (activePlan && activePlan.id) ? activePlan.id : "" %>';
    let isSubmittingMeal = false;
    let isSubmittingFood = {};

    // ========================
    // FOOD AUTOCOMPLETE
    // ========================
    let _foodSearchTimer = null;

    function onFoodNameInput(input) {
        const wrapper = input.closest('.food-search-wrapper');
        const dropdown = wrapper.querySelector('.food-autocomplete-dropdown');
        const q = input.value.trim();

        clearTimeout(_foodSearchTimer);

        if (q.length < 3) {
            dropdown.style.display = 'none';
            return;
        }

        dropdown.innerHTML = '<div class="food-autocomplete-loading">🔍 Buscando...</div>';
        dropdown.style.display = 'block';

        _foodSearchTimer = setTimeout(() => doFoodSearch(q, input, dropdown), 800);
    }

    async function doFoodSearch(q, input, dropdown) {
        try {
            const res = await fetch('/diet/food-search?q=' + encodeURIComponent(q));
            const data = await res.json();

            if (!data.success || data.results.length === 0) {
                dropdown.innerHTML = '<div class="food-autocomplete-empty">Nenhum resultado encontrado</div>';
                return;
            }

            dropdown.innerHTML = data.results.map((item, i) =>
                `<div class="food-autocomplete-item" onclick="selectFoodResult(this, ${i})"
                      data-name="${escapeAttr(item.name)}"
                      data-calories="${item.calories}"
                      data-protein="${item.protein}"
                      data-carbs="${item.carbs}"
                      data-fat="${item.fat}">
                    <span class="food-autocomplete-source">${escapeHtml(item.source)}</span>
                    <div class="food-autocomplete-name">${escapeHtml(item.name)}</div>
                    <div class="food-autocomplete-macros">
                        <span class="kcal">⚡ ${item.calories} kcal</span>
                        <span>🥩 ${item.protein}g prot</span>
                        <span>🌾 ${item.carbs}g carbs</span>
                        <span>🧈 ${item.fat}g gord</span>
                        <small style="color:#555">por 100g</small>
                    </div>
                </div>`
            ).join('');

        } catch (e) {
            dropdown.innerHTML = '<div class="food-autocomplete-empty">Erro na busca</div>';
        }
    }

    function selectFoodResult(el, i) {
        const form = el.closest('form');
        const nameInput = form.querySelector('.food-name');
        const dropdown = el.closest('.food-autocomplete-dropdown');

        nameInput.value = el.dataset.name;

        // Store base values per 100g on the form for recalculation
        form.dataset.base100Calories = el.dataset.calories;
        form.dataset.base100Protein  = el.dataset.protein;
        form.dataset.base100Carbs    = el.dataset.carbs;
        form.dataset.base100Fat      = el.dataset.fat;

        const qty = parseFloat(form.querySelector('.food-quantity').value) || 100;
        const unit = form.querySelector('.food-unit').value;
        applyNutritionForQty(form, qty, unit);

        dropdown.style.display = 'none';
        form.querySelector('.food-quantity').focus();
    }

    function onQuantityInput(input) {
        const form = input.closest('form');
        if (!form.dataset.base100Calories) return; // no food selected yet
        const qty = parseFloat(input.value) || 0;
        const unit = form.querySelector('.food-unit').value;
        applyNutritionForQty(form, qty, unit);
    }

    function onUnitChange(select) {
        const form = select.closest('form');
        if (!form.dataset.base100Calories) return; // no food selected yet
        const qty = parseFloat(form.querySelector('.food-quantity').value) || 0;
        applyNutritionForQty(form, qty, select.value);
    }

    function applyNutritionForQty(form, qty, unit) {
        const scalable = unit === 'g' || unit === 'ml';
        const hint = form.querySelector('.unit-hint');

        if (scalable) {
            // Scale linearly: API values are per 100g/ml
            if (hint) hint.style.display = 'none';
            const factor = qty / 100;
            form.querySelector('.food-calories').value = qty > 0 ? Math.round(form.dataset.base100Calories * factor) : '';
            form.querySelector('.food-protein').value  = qty > 0 ? parseFloat((form.dataset.base100Protein  * factor).toFixed(1)) : '';
            form.querySelector('.food-carbs').value    = qty > 0 ? parseFloat((form.dataset.base100Carbs    * factor).toFixed(1)) : '';
            form.querySelector('.food-fat').value      = qty > 0 ? parseFloat((form.dataset.base100Fat      * factor).toFixed(1)) : '';
        } else {
            // For un/porção/outro: fill with per-100g base and let admin adjust
            if (hint) hint.style.display = 'block';
            form.querySelector('.food-calories').value = form.dataset.base100Calories || '';
            form.querySelector('.food-protein').value  = form.dataset.base100Protein  || '';
            form.querySelector('.food-carbs').value    = form.dataset.base100Carbs    || '';
            form.querySelector('.food-fat').value      = form.dataset.base100Fat      || '';
        }
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', e => {
        if (!e.target.closest('.food-search-wrapper')) {
            document.querySelectorAll('.food-autocomplete-dropdown').forEach(d => d.style.display = 'none');
        }
    });

    function escapeHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
    function escapeAttr(str) {
        return String(str).replace(/"/g,'&quot;');
    }

    // 🔧 Get CSRF token with fallbacks
    function getCsrfToken() {
        if (typeof csrfToken !== 'undefined' && csrfToken) return csrfToken;
        const meta = document.querySelector('meta[name="csrf-token"]');
        if (meta) return meta.getAttribute('content');
        const input = document.querySelector('input[name="_csrf"]');
        if (input) return input.value;
        throw new Error('CSRF token not found');
    }

    async function toggleDietTemplate(planId, btn) {
        try {
            const r = await fetch('/diet/plans/' + planId + '/toggle-template', {
                method: 'PATCH',
                headers: { 'X-CSRF-Token': getCsrfToken() }
            });
            const d = await r.json();
            if (d.success) {
                if (d.isTemplate) {
                    btn.textContent = '📚 Na Biblioteca';
                    showToast('Plano movido para a biblioteca!', 'success');
                } else {
                    btn.textContent = '📋 Tornar Template';
                    showToast('Plano removido da biblioteca', 'success');
                }
            } else showToast(d.message || 'Erro', 'error');
        } catch(_) { showToast('Erro de conexão', 'error'); }
    }

    function showAddMealForm() {
        if (!activePlanId) {
            showToast('Por favor, selecione um plano de dieta primeiro! ⚠️', 'error');
            return;
        }
        document.getElementById('addMealForm').style.display = 'block';
        document.getElementById('mealName').focus();
    }

    function hideAddMealForm() {
        document.getElementById('addMealForm').style.display = 'none';
        document.getElementById('mealName').value = '';
        document.getElementById('mealTime').value = '';
    }

    // 🔧 Submit meal with race condition prevention
    function submitAddMeal(event) {
        event.preventDefault();
        
        if (isSubmittingMeal) {
            showToast('Aguarde... sua refeição está sendo criada 🔄', 'warning');
            return;
        }
        
        if (!activePlanId) {
            showToast('Erro: Plano de dieta não selecionado! ❌', 'error');
            return;
        }

        const name = document.getElementById('mealName').value?.trim();
        const time = document.getElementById('mealTime').value?.trim();
        const submitBtn = event.target.querySelector('button[type="submit"]');

        // 🔧 Validação
        if (!name || name.length < 2) {
            showToast('Nome da refeição deve ter pelo menos 2 caracteres ⚠️', 'error');
            return;
        }

        if (name.length > 100) {
            showToast('Nome muito longo (máx 100 caracteres) ⚠️', 'error');
            return;
        }

        try {
            isSubmittingMeal = true;
            submitBtn.disabled = true;

            fetch(`/diet/meals`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': getCsrfToken()
                },
                body: JSON.stringify({
                    mealPlanId: parseInt(activePlanId),
                    name,
                    time: time || null
                })
            })
            .then(res => {
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                return res.json();
            })
            .then(data => {
                if (data.success) {
                    showToast('Refeição criada com sucesso! ✓', 'success');
                    hideAddMealForm();
                    setTimeout(() => location.reload(), 800);
                } else {
                    throw new Error(data.message || 'Erro desconhecido');
                }
            })
            .catch(err => {
                console.error('Meal error:', err);
                showToast('Erro: ' + err.message, 'error');
            })
            .finally(() => {
                isSubmittingMeal = false;
                submitBtn.disabled = false;
            });
        } catch (error) {
            console.error('Fatal error:', error);
            showToast('Erro ao criar refeição ❌', 'error');
            isSubmittingMeal = false;
            submitBtn.disabled = false;
        }
    }

    function switchPlan(planId) {
        if (!planId) {
            showToast('Selecione um plano válido ⚠️', 'error');
            return;
        }

        try {
            fetch(`/diet/plans/${planId}/activate`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': getCsrfToken()
                }
            })
            .then(res => {
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                return res.json();
            })
            .then(data => {
                if (data.success) {
                    showToast('Plano ativado ✓', 'success');
                    setTimeout(() => location.reload(), 500);
                } else {
                    throw new Error(data.message || 'Erro desconhecido');
                }
            })
            .catch(err => {
                console.error('Switch plan error:', err);
                showToast('Erro: ' + err.message, 'error');
            });
        } catch (error) {
            console.error('Fatal error:', error);
            showToast('Erro ao ativar plano ❌', 'error');
        }
    }

    function deleteMeal(mealId) {
        if (confirm('Deletar essa refeição? Todos os alimentos serão removidos.')) {
            try {
                fetch(`/diet/meals/${mealId}`, {
                    method: 'DELETE',
                    headers: {
                        'X-CSRF-Token': getCsrfToken()
                    }
                })
                .then(res => {
                    if (!res.ok) throw new Error(`HTTP ${res.status}`);
                    return res.json();
                })
                .then(data => {
                    if (data.success) {
                        showToast('Refeição removida ✓', 'success');
                        setTimeout(() => location.reload(), 500);
                    } else {
                        throw new Error(data.message || 'Erro desconhecido');
                    }
                })
                .catch(err => {
                    console.error('Delete meal error:', err);
                    showToast('Erro: ' + err.message, 'error');
                });
            } catch (error) {
                console.error('Fatal error:', error);
                showToast('Erro ao remover refeição ❌', 'error');
            }
        }
    }

    function deleteFood(foodId) {
        if (confirm('Deletar esse alimento?')) {
            try {
                fetch(`/diet/foods/${foodId}`, {
                    method: 'DELETE',
                    headers: {
                        'X-CSRF-Token': getCsrfToken()
                    }
                })
                .then(res => {
                    if (!res.ok) throw new Error(`HTTP ${res.status}`);
                    return res.json();
                })
                .then(data => {
                    if (data.success) {
                        document.querySelector(`[data-food-id="${foodId}"]`)?.remove();
                        showToast('Alimento removido ✓', 'success');
                        updateMealTotals();
                    } else {
                        throw new Error(data.message || 'Erro desconhecido');
                    }
                })
                .catch(err => {
                    console.error('Delete food error:', err);
                    showToast('Erro: ' + err.message, 'error');
                });
            } catch (error) {
                console.error('Fatal error:', error);
                showToast('Erro ao remover alimento ❌', 'error');
            }
        }
    }

    // 🔧 Add food with validation + race condition prevention
    function addFood(event, mealId) {
        event.preventDefault();
        
        if (isSubmittingFood[mealId]) {
            showToast('Aguarde... alimento está sendo adicionado 🔄', 'warning');
            return;
        }

        const form = event.target;
        const name = form.querySelector('.food-name').value?.trim();
        const quantityValue = form.querySelector('.food-quantity').value?.trim();
        const quantityUnit = form.querySelector('.food-unit').value;
        const quantity = quantityValue ? `${quantityValue}${quantityUnit}` : null;
        const submitBtn = form.querySelector('button[type="submit"]');

        // 🔧 Validação
        if (!name || name.length < 2) {
            showToast('Nome do alimento deve ter pelo menos 2 caracteres ⚠️', 'error');
            return;
        }

        if (name.length > 100) {
            showToast('Nome muito longo (máx 100 caracteres) ⚠️', 'error');
            return;
        }

        // Validar se há pelo menos uma propriedade nutricional
        const calories = form.querySelector('.food-calories').value;
        const protein = form.querySelector('.food-protein').value;
        const carbs = form.querySelector('.food-carbs').value;
        const fat = form.querySelector('.food-fat').value;

        if (!calories && !protein && !carbs && !fat) {
            showToast('Adicione pelo menos uma informação nutricional ⚠️', 'error');
            return;
        }

        // Validar valores numéricos
        const numFields = { calories, protein, carbs, fat };
        for (const [field, value] of Object.entries(numFields)) {
            if (value && isNaN(parseFloat(value))) {
                showToast(`${field} deve ser um número válido ⚠️`, 'error');
                return;
            }
            if (value && parseFloat(value) < 0) {
                showToast(`${field} não pode ser negativo ⚠️`, 'error');
                return;
            }
        }

        try {
            isSubmittingFood[mealId] = true;
            submitBtn.disabled = true;

            const data = {
                mealId,
                name,
                quantity,
                calories: calories ? parseFloat(calories) : null,
                protein: protein ? parseFloat(protein) : null,
                carbs: carbs ? parseFloat(carbs) : null,
                fat: fat ? parseFloat(fat) : null,
                notes: form.querySelector('.food-notes-input').value?.trim() || null
            };

            fetch(`/diet/meals/${mealId}/foods`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': getCsrfToken()
                },
                body: JSON.stringify(data)
            })
            .then(res => {
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                return res.json();
            })
            .then(result => {
                if (result.success) {
                    showToast('Alimento adicionado com sucesso! ✓', 'success');
                    form.reset();
                    updateMealTotals();
                    setTimeout(() => location.reload(), 800);
                } else {
                    throw new Error(result.message || 'Erro desconhecido');
                }
            })
            .catch(err => {
                console.error('Add food error:', err);
                showToast('Erro: ' + err.message, 'error');
            })
            .finally(() => {
                isSubmittingFood[mealId] = false;
                submitBtn.disabled = false;
            });
        } catch (error) {
            console.error('Fatal error:', error);
            showToast('Erro ao adicionar alimento ❌', 'error');
            isSubmittingFood[mealId] = false;
            submitBtn.disabled = false;
        }
    }

    function createNewPlan() {
        const name = prompt('Nome do novo plano de dieta:');
        if (!name) return;

        const trimmedName = name.trim();
        if (trimmedName.length < 2) {
            showToast('Nome do plano deve ter pelo menos 2 caracteres ⚠️', 'error');
            return;
        }

        if (trimmedName.length > 100) {
            showToast('Nome muito longo (máx 100 caracteres) ⚠️', 'error');
            return;
        }

        try {
            fetch(`/diet/plans`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': getCsrfToken()
                },
                body: JSON.stringify({ name: trimmedName })
            })
            .then(res => {
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                return res.json();
            })
            .then(result => {
                if (result.success) {
                    showToast('Plano criado com sucesso! ✓', 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    throw new Error(result.message || 'Erro desconhecido');
                }
            })
            .catch(err => {
                console.error('Create plan error:', err);
                showToast('Erro: ' + err.message, 'error');
            });
        } catch (error) {
            console.error('Fatal error:', error);
            showToast('Erro ao criar plano ❌', 'error');
        }
    }

    function updateMealTotals() {
        document.querySelectorAll('.meal-card').forEach(section => {
            const foods = section.querySelectorAll('tr[data-food-id]');
            let totalCals = 0, totalProt = 0, totalCarbs = 0, totalFat = 0;

            foods.forEach(food => {
                totalCals += parseFloat(food.dataset.calories || 0);
                totalProt += parseFloat(food.dataset.protein || 0);
                totalCarbs += parseFloat(food.dataset.carbs || 0);
                totalFat += parseFloat(food.dataset.fat || 0);
            });

            const totalsEl = section.querySelector('.meal-totals');
            if (totalsEl) {
                totalsEl.innerHTML = `
                    <div class="nutrient">🔥 ${totalCals.toFixed(1)} kcal</div>
                    <div class="nutrient">💪 ${totalProt.toFixed(1)}g</div>
                    <div class="nutrient">🍞 ${totalCarbs.toFixed(1)}g</div>
                    <div class="nutrient">🧈 ${totalFat.toFixed(1)}g</div>
                `;
            }
        });
    }

    function toggleAddFoodForm(mealId) {
        const form = document.getElementById(`addFoodForm-${mealId}`);
        if (form) {
            const isHidden = form.style.display === 'none' || form.style.display === '';
            form.style.display = isHidden ? 'block' : 'none';
            if (isHidden) {
                form.querySelector('.food-name')?.focus();
            }
        }
    }
</script>
