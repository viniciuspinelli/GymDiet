<meta name="csrf-token" content="<%= csrfToken %>">

<div class="plans-page">

    <div class="page-header">
        <div>
            <h1>Planos de Treino</h1>
            <p class="page-subtitle">Gerencie seus planos e exercicios</p>
        </div>
        <button class="btn btn-primary" onclick="openCreateModal()">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Novo Plano
        </button>
    </div>

    <!-- Lista de Planos -->
    <% if (plans.length > 0) { %>
        <div class="plans-simple-list">
            <% plans.forEach(plan => { %>
                <div class="plan-row" id="plan-row-<%= plan.id %>">
                    <div class="plan-row-info">
                        <span class="plan-row-name"><%= plan.name %></span>
                        <div class="plan-row-meta">
                            <% if (plan.dayOfWeek) { %><span class="day-badge"><%= plan.dayOfWeek %></span><% } %>
                            <span class="badge-count"><%= plan.exercise_count %> exerc.</span>
                            <% if (!plan.isActive) { %><span class="badge badge-warning">Inativo</span><% } %>
                        </div>
                    </div>
                    <div class="plan-row-actions">
                        <button class="btn btn-secondary btn-sm" onclick="openEditModal(<%= plan.id %>, '<%= plan.name.replace(/\'/g, `\\'`) %>', '<%= (plan.dayOfWeek || '').replace(/\'/g, `\\'`) %>', '<%= (plan.description || '').replace(/\'/g, `\\'`) %>', <%= plan.isActive %>)">
                            Editar
                        </button>
                        <button class="btn btn-danger btn-sm" onclick="deletePlan(<%= plan.id %>, '<%= plan.name.replace(/\'/g, `\\'`) %>')">
                            Deletar
                        </button>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <span class="empty-state-icon">&#127947;</span>
            <p>Nenhum plano criado ainda</p>
            <small>Crie seu primeiro plano de treino</small>
            <button class="btn btn-primary" onclick="openCreateModal()">Criar Plano</button>
        </div>
    <% } %>

</div>

<!-- MODAL: CRIAR PLANO -->
<div class="modal-backdrop" id="modal-create" onclick="closeModal('modal-create')">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2>Novo Plano</h2>
            <button class="modal-close" onclick="closeModal('modal-create')">&times;</button>
        </div>
        <form onsubmit="submitCreate(event)">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-row">
                <div class="form-group">
                    <label>Nome *</label>
                    <input type="text" id="c-name" name="name" placeholder="ex: Peito e Costas" required>
                </div>
                <div class="form-group">
                    <label>Dia</label>
                    <select id="c-day" name="dayOfWeek">
                        <option value="">Nenhum</option>
                        <option>Segunda</option><option>Terca</option><option>Quarta</option>
                        <option>Quinta</option><option>Sexta</option><option>Sabado</option><option>Domingo</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>Descricao</label>
                <textarea id="c-desc" name="description" rows="2" placeholder="Objetivo do plano..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modal-create')">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="btn-create">Criar Plano</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL: EDITAR PLANO + EXERCICIOS -->
<div class="modal-backdrop modal-wide" id="modal-edit" onclick="closeModal('modal-edit')">
    <div class="modal-content modal-content-wide" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2 id="edit-modal-title">Editar Plano</h2>
            <button class="modal-close" onclick="closeModal('modal-edit')">&times;</button>
        </div>

        <!-- Dados do Plano -->
        <form onsubmit="submitEdit(event)" style="margin-bottom: 0;">
            <input type="hidden" id="e-id">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-row">
                <div class="form-group">
                    <label>Nome *</label>
                    <input type="text" id="e-name" required>
                </div>
                <div class="form-group">
                    <label>Dia</label>
                    <select id="e-day">
                        <option value="">Nenhum</option>
                        <option>Segunda</option><option>Terca</option><option>Quarta</option>
                        <option>Quinta</option><option>Sexta</option><option>Sabado</option><option>Domingo</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>Descricao</label>
                <textarea id="e-desc" rows="2"></textarea>
            </div>
            <div class="form-group">
                <label class="label-checkbox">
                    <input type="checkbox" id="e-active" value="true">
                    <span>Plano ativo</span>
                </label>
            </div>
            <div style="display:flex; gap:8px; padding-top: 8px;">
                <button type="submit" class="btn btn-primary btn-sm">Salvar Plano</button>
            </div>
        </form>

        <div class="modal-divider"></div>

        <!-- Exercicios do Plano -->
        <div class="modal-exercises-section">
            <div class="modal-exercises-header">
                <span class="exercises-section-label">EXERCICIOS</span>
            </div>
            <div id="modal-exercises-list"></div>

            <!-- Formulario adicionar exercicio -->
            <details class="add-exercise-details" id="add-ex-details">
                <summary class="add-exercise-summary">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Adicionar Exercicio
                </summary>
                <div class="add-exercise-body">
                    <form id="form-add-ex" onsubmit="submitAddEx(event)">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="form-grid-3">
                            <div class="form-group">
                                <label>Nome *</label>
                                <input type="text" id="ax-name" name="name" placeholder="ex: Supino" required>
                            </div>
                            <div class="form-group">
                                <label>Series *</label>
                                <input type="number" id="ax-sets" name="sets" placeholder="4" min="1" max="20" required>
                            </div>
                            <div class="form-group">
                                <label>Reps *</label>
                                <input type="text" id="ax-reps" name="reps" placeholder="8-12" required>
                            </div>
                        </div>
                        <div class="form-grid-3">
                            <div class="form-group">
                                <label>Carga</label>
                                <input type="text" id="ax-weight" name="weight" placeholder="60kg">
                            </div>
                            <div class="form-group">
                                <label>Descanso (seg)</label>
                                <input type="number" id="ax-rest" name="restSeconds" placeholder="60" min="0">
                            </div>
                            <div class="form-group">
                                <label>Notas</label>
                                <input type="text" id="ax-notes" name="notes" placeholder="Dicas...">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">Adicionar</button>
                    </form>
                </div>
            </details>
        </div>
    </div>
</div>

<!-- MODAL: EDITAR EXERCICIO -->
<div class="modal-backdrop" id="modal-edit-ex" onclick="closeModal('modal-edit-ex')">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2>Editar Exercicio</h2>
            <button class="modal-close" onclick="closeModal('modal-edit-ex')">&times;</button>
        </div>
        <form onsubmit="submitEditEx(event)">
            <input type="hidden" id="ex-id">
            <input type="hidden" id="ex-plan-id">
            <div class="form-row">
                <div class="form-group" style="flex:2">
                    <label>Nome *</label>
                    <input type="text" id="ex-name" required>
                </div>
                <div class="form-group">
                    <label>Series *</label>
                    <input type="number" id="ex-sets" min="1" max="20" required>
                </div>
                <div class="form-group">
                    <label>Reps *</label>
                    <input type="text" id="ex-reps" required>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Carga</label>
                    <input type="text" id="ex-weight">
                </div>
                <div class="form-group">
                    <label>Descanso (seg)</label>
                    <input type="number" id="ex-rest" min="0">
                </div>
            </div>
            <div class="form-group">
                <label>Notas</label>
                <textarea id="ex-notes" rows="2"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modal-edit-ex')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Salvar</button>
            </div>
        </form>
    </div>
</div>

<script>
const _csrf = document.querySelector('meta[name="csrf-token"]').content;
let _currentPlanId = null;

// --- Modals ---
function openModal(id) { document.getElementById(id).classList.add('active'); document.body.style.overflow = 'hidden'; }
function closeModal(id) { document.getElementById(id).classList.remove('active'); document.body.style.overflow = ''; }
document.addEventListener('keydown', e => { if (e.key === 'Escape') { document.querySelectorAll('.modal-backdrop.active').forEach(m => m.classList.remove('active')); document.body.style.overflow = ''; }});

// --- Toast ---
function toast(msg, type = 'info') {
    let c = document.querySelector('.toast-container');
    if (!c) { c = document.createElement('div'); c.className = 'toast-container'; document.body.appendChild(c); }
    const t = document.createElement('div');
    t.className = 'toast toast-' + type;
    t.textContent = msg;
    c.appendChild(t);
    requestAnimationFrame(() => t.classList.add('show'));
    setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 400); }, 3500);
}

// --- Criar Plano ---
function openCreateModal() {
    document.querySelector('#modal-create form').reset();
    openModal('modal-create');
    document.getElementById('c-name').focus();
}
async function submitCreate(e) {
    e.preventDefault();
    const fd = new FormData(e.target);
    const btn = document.getElementById('btn-create');
    btn.disabled = true; btn.textContent = 'Criando...';
    try {
        const r = await fetch('/workouts/plans', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf }, body: JSON.stringify({ name: fd.get('name'), description: fd.get('description') || null, dayOfWeek: fd.get('dayOfWeek') || null }) });
        const d = await r.json();
        if (d.success) { toast('Plano criado!', 'success'); closeModal('modal-create'); setTimeout(() => location.reload(), 1200); }
        else toast(d.message || 'Erro', 'error');
    } catch(_) { toast('Erro de conexao', 'error'); }
    finally { btn.disabled = false; btn.textContent = 'Criar Plano'; }
}

// --- Editar Plano ---
function openEditModal(id, name, day, desc, isActive) {
    _currentPlanId = id;
    document.getElementById('e-id').value = id;
    document.getElementById('e-name').value = name;
    document.getElementById('e-day').value = day || '';
    document.getElementById('e-desc').value = desc || '';
    document.getElementById('e-active').checked = isActive;
    document.getElementById('edit-modal-title').textContent = name;
    document.getElementById('add-ex-details').removeAttribute('open');
    document.getElementById('form-add-ex').reset();
    loadExercises(id);
    openModal('modal-edit');
    document.getElementById('e-name').focus();
}
async function submitEdit(e) {
    e.preventDefault();
    const id = document.getElementById('e-id').value;
    const body = {
        name: document.getElementById('e-name').value,
        description: document.getElementById('e-desc').value || null,
        dayOfWeek: document.getElementById('e-day').value || null,
        isActive: document.getElementById('e-active').checked
    };
    try {
        const r = await fetch('/workouts/plans/' + id, { method: 'PUT', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf }, body: JSON.stringify(body) });
        const d = await r.json();
        if (d.success) { toast('Plano atualizado!', 'success'); setTimeout(() => location.reload(), 1200); }
        else toast(d.message || 'Erro', 'error');
    } catch(_) { toast('Erro de conexao', 'error'); }
}

// --- Deletar Plano ---
async function deletePlan(id, name) {
    if (!confirm('Deletar "' + name + '"? Os exercicios serao removidos.')) return;
    try {
        const r = await fetch('/workouts/plans/' + id, { method: 'DELETE', headers: { 'X-CSRF-Token': _csrf } });
        const d = await r.json();
        if (d.success) { toast('Plano deletado!', 'success'); setTimeout(() => location.reload(), 1000); }
        else toast(d.message || 'Erro', 'error');
    } catch(_) { toast('Erro de conexao', 'error'); }
}

// --- Listar Exercicios ---
async function loadExercises(planId) {
    const list = document.getElementById('modal-exercises-list');
    list.innerHTML = '<p class="exercises-loading">Carregando...</p>';
    try {
        const r = await fetch('/workouts/plans/' + planId + '/exercises');
        const d = await r.json();
        if (!d.success || d.exercises.length === 0) {
            list.innerHTML = '<p class="no-exercises-msg">Nenhum exercicio ainda</p>';
            return;
        }
        list.innerHTML = d.exercises.map(function(ex, i) {
            return '<div class="exercise-row" id="exrow-' + ex.id + '">' +
                '<div class="exercise-row-number">' + (i+1) + '</div>' +
                '<div class="exercise-row-info">' +
                    '<span class="exercise-row-name">' + ex.name + '</span>' +
                    '<div class="exercise-row-meta">' +
                        '<span class="meta-pill">' + ex.sets + 'x' + ex.reps + '</span>' +
                        (ex.weight ? '<span class="meta-pill">' + ex.weight + '</span>' : '') +
                        (ex.restSeconds ? '<span class="meta-pill">' + ex.restSeconds + 's</span>' : '') +
                        (ex.notes ? '<span class="meta-pill meta-notes">' + ex.notes + '</span>' : '') +
                    '</div>' +
                '</div>' +
                '<div class="exercise-row-actions">' +
                    '<button class="btn-icon" onclick="openEditExModal(' + ex.id + ',' + planId + ',\'' + esc(ex.name) + '\',' + ex.sets + ',\'' + esc(ex.reps) + '\',\'' + esc(ex.weight||'') + '\',' + (ex.restSeconds||0) + ',\'' + esc(ex.notes||'') + '\')" title="Editar">' +
                        '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>' +
                    '</button>' +
                    '<button class="btn-icon btn-icon-danger" onclick="deleteEx(' + ex.id + ', \'' + esc(ex.name) + '\')" title="Deletar">' +
                        '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>' +
                    '</button>' +
                '</div>' +
            '</div>';
        }).join('');
    } catch(_) { list.innerHTML = '<p class="error-msg">Erro ao carregar</p>'; }
}

function esc(s) { return String(s||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'"); }

// --- Adicionar Exercicio ---
async function submitAddEx(e) {
    e.preventDefault();
    const fd = new FormData(e.target);
    const btn = e.target.querySelector('[type="submit"]');
    btn.disabled = true;
    try {
        const r = await fetch('/workouts/plans/' + _currentPlanId + '/exercises', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf }, body: JSON.stringify({ name: fd.get('name'), sets: fd.get('sets'), reps: fd.get('reps'), weight: fd.get('weight')||null, restSeconds: fd.get('restSeconds')||null, notes: fd.get('notes')||null }) });
        const d = await r.json();
        if (d.success) { toast('Exercicio adicionado!', 'success'); e.target.reset(); document.getElementById('add-ex-details').removeAttribute('open'); loadExercises(_currentPlanId); }
        else toast(d.message || 'Erro', 'error');
    } catch(_) { toast('Erro de conexao', 'error'); }
    finally { btn.disabled = false; }
}

// --- Editar Exercicio ---
function openEditExModal(id, planId, name, sets, reps, weight, rest, notes) {
    document.getElementById('ex-id').value = id;
    document.getElementById('ex-plan-id').value = planId;
    document.getElementById('ex-name').value = name;
    document.getElementById('ex-sets').value = sets;
    document.getElementById('ex-reps').value = reps;
    document.getElementById('ex-weight').value = weight || '';
    document.getElementById('ex-rest').value = rest || '';
    document.getElementById('ex-notes').value = notes || '';
    openModal('modal-edit-ex');
}
async function submitEditEx(e) {
    e.preventDefault();
    const id = document.getElementById('ex-id').value;
    const planId = document.getElementById('ex-plan-id').value;
    const body = { name: document.getElementById('ex-name').value, sets: document.getElementById('ex-sets').value, reps: document.getElementById('ex-reps').value, weight: document.getElementById('ex-weight').value||null, restSeconds: document.getElementById('ex-rest').value||null, notes: document.getElementById('ex-notes').value||null };
    try {
        const r = await fetch('/workouts/exercises/' + id, { method: 'PUT', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf }, body: JSON.stringify(body) });
        const d = await r.json();
        if (d.success) { toast('Exercicio atualizado!', 'success'); closeModal('modal-edit-ex'); loadExercises(planId); }
        else toast(d.message || 'Erro', 'error');
    } catch(_) { toast('Erro de conexao', 'error'); }
}

// --- Deletar Exercicio ---
async function deleteEx(id, name) {
    if (!confirm('Deletar "' + name + '"?')) return;
    try {
        const r = await fetch('/workouts/exercises/' + id, { method: 'DELETE', headers: { 'X-CSRF-Token': _csrf } });
        const d = await r.json();
        if (d.success) { toast('Deletado!', 'success'); loadExercises(_currentPlanId); }
        else toast(d.message || 'Erro', 'error');
    } catch(_) { toast('Erro de conexao', 'error'); }
}
</script>
