<meta name="csrf-token" content="<%= csrfToken %>">

<div class="plans-page">

    <!-- Page Header -->
    <div class="page-header">
        <div>
            <h1>Gerenciar Treinos</h1>
            <p class="page-subtitle">Crie e edite seus planos e exercicios</p>
        </div>
        <button class="btn btn-primary" onclick="openCreatePlanModal()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Novo Plano
        </button>
    </div>

    <!-- Plans List -->
    <% if (plans.length > 0) { %>
        <div class="plans-list">
            <% plans.forEach(plan => { %>
                <div class="plan-card" id="plan-card-<%= plan.id %>">
                    <div class="plan-card-header">
                        <div class="plan-card-info">
                            <div class="plan-card-title-row">
                                <h2 class="plan-card-name"><%= plan.name %></h2>
                                <div class="plan-badges">
                                    <% if (plan.dayOfWeek) { %>
                                        <span class="day-badge"><%= plan.dayOfWeek %></span>
                                    <% } %>
                                    <span class="badge-count" id="exercise-count-<%= plan.id %>"><%= plan.exercise_count %> exerc.</span>
                                    <% if (!plan.isActive) { %>
                                        <span class="badge badge-warning">Inativo</span>
                                    <% } %>
                                </div>
                            </div>
                            <% if (plan.description) { %>
                                <p class="plan-card-description"><%= plan.description %></p>
                            <% } %>
                        </div>
                        <div class="plan-card-actions">
                            <button class="btn btn-secondary btn-sm" onclick="openEditPlanModal(<%= plan.id %>, '<%= plan.name.replace(/\'/g, `\\'`) %>', '<%= (plan.dayOfWeek || '').replace(/\'/g, `\\'`) %>', '<%= (plan.description || '').replace(/\'/g, `\\'`) %>', <%= plan.isActive %>)">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                Editar
                            </button>
                            <button class="btn btn-danger btn-sm" onclick="deletePlan(<%= plan.id %>, '<%= plan.name.replace(/\'/g, `\\'`) %>')">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                Deletar
                            </button>
                        </div>
                    </div>

                    <div class="plan-exercises-section">
                        <div class="exercises-section-header">
                            <span class="exercises-section-label">EXERCICIOS</span>
                        </div>
                        <div class="exercises-dynamic-list" id="exercises-<%= plan.id %>">
                            <div class="exercises-loading"><span>Carregando...</span></div>
                        </div>
                        <details class="add-exercise-details">
                            <summary class="add-exercise-summary">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Adicionar Exercicio
                            </summary>
                            <div class="add-exercise-body">
                                <form class="add-exercise-form" id="addExerciseForm-<%= plan.id %>" onsubmit="submitAddExercise(event, <%= plan.id %>)">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <div class="form-grid-3">
                                        <div class="form-group">
                                            <label>Nome *</label>
                                            <input type="text" name="name" placeholder="ex: Supino Reto" required>
                                        </div>
                                        <div class="form-group">
                                            <label>Series *</label>
                                            <input type="number" name="sets" placeholder="4" min="1" max="20" required>
                                        </div>
                                        <div class="form-group">
                                            <label>Repeticoes *</label>
                                            <input type="text" name="reps" placeholder="8-12" required>
                                        </div>
                                    </div>
                                    <div class="form-grid-3">
                                        <div class="form-group">
                                            <label>Carga</label>
                                            <input type="text" name="weight" placeholder="ex: 60kg">
                                        </div>
                                        <div class="form-group">
                                            <label>Descanso (seg)</label>
                                            <input type="number" name="restSeconds" placeholder="60" min="0">
                                        </div>
                                        <div class="form-group">
                                            <label>Notas</label>
                                            <input type="text" name="notes" placeholder="Dicas tecnicas...">
                                        </div>
                                    </div>
                                    <div class="form-actions-row">
                                        <button type="submit" class="btn btn-primary btn-sm">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                            Adicionar
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </details>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <span class="empty-state-icon">&#127947;</span>
            <p>Nenhum plano de treino criado ainda</p>
            <small>Clique em "Novo Plano" para comecar</small>
            <button class="btn btn-primary" onclick="openCreatePlanModal()">Criar Primeiro Plano</button>
        </div>
    <% } %>

</div>

<!-- MODAL: CRIAR PLANO -->
<div class="modal-backdrop" id="modal-create-plan" onclick="closeModal('modal-create-plan')">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2>Novo Plano de Treino</h2>
            <button class="modal-close" onclick="closeModal('modal-create-plan')">&times;</button>
        </div>
        <form id="createPlanForm" onsubmit="submitCreatePlan(event)">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-row">
                <div class="form-group">
                    <label for="create-plan-name">Nome do Plano *</label>
                    <input type="text" id="create-plan-name" name="name" placeholder="ex: Peito e Costas" required>
                </div>
                <div class="form-group">
                    <label for="create-plan-day">Dia da Semana</label>
                    <select id="create-plan-day" name="dayOfWeek">
                        <option value="">Selecione...</option>
                        <option value="Segunda">Segunda</option>
                        <option value="Terca">Terca</option>
                        <option value="Quarta">Quarta</option>
                        <option value="Quinta">Quinta</option>
                        <option value="Sexta">Sexta</option>
                        <option value="Sabado">Sabado</option>
                        <option value="Domingo">Domingo</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label for="create-plan-desc">Descricao</label>
                <textarea id="create-plan-desc" name="description" placeholder="Objetivo ou observacoes..." rows="2"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modal-create-plan')">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="btn-create-plan">Criar Plano</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL: EDITAR PLANO -->
<div class="modal-backdrop" id="modal-edit-plan" onclick="closeModal('modal-edit-plan')">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2>Editar Plano</h2>
            <button class="modal-close" onclick="closeModal('modal-edit-plan')">&times;</button>
        </div>
        <form id="editPlanForm" onsubmit="submitEditPlan(event)">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" id="edit-plan-id" name="planId">
            <div class="form-row">
                <div class="form-group">
                    <label for="edit-plan-name">Nome do Plano *</label>
                    <input type="text" id="edit-plan-name" name="name" required>
                </div>
                <div class="form-group">
                    <label for="edit-plan-day">Dia da Semana</label>
                    <select id="edit-plan-day" name="dayOfWeek">
                        <option value="">Nenhum</option>
                        <option value="Segunda">Segunda</option>
                        <option value="Terca">Terca</option>
                        <option value="Quarta">Quarta</option>
                        <option value="Quinta">Quinta</option>
                        <option value="Sexta">Sexta</option>
                        <option value="Sabado">Sabado</option>
                        <option value="Domingo">Domingo</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label for="edit-plan-desc">Descricao</label>
                <textarea id="edit-plan-desc" name="description" rows="2"></textarea>
            </div>
            <div class="form-group">
                <label class="label-checkbox">
                    <input type="checkbox" id="edit-plan-active" name="isActive" value="true">
                    <span>Plano ativo (aparece na lista de treinos)</span>
                </label>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modal-edit-plan')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Salvar Alteracoes</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL: EDITAR EXERCICIO -->
<div class="modal-backdrop" id="modal-edit-exercise" onclick="closeModal('modal-edit-exercise')">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2>Editar Exercicio</h2>
            <button class="modal-close" onclick="closeModal('modal-edit-exercise')">&times;</button>
        </div>
        <form id="editExerciseForm" onsubmit="submitEditExercise(event)">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" id="edit-ex-id" name="exerciseId">
            <input type="hidden" id="edit-ex-plan-id" name="planId">
            <div class="form-row">
                <div class="form-group" style="flex:2">
                    <label for="edit-ex-name">Nome *</label>
                    <input type="text" id="edit-ex-name" name="name" required>
                </div>
                <div class="form-group">
                    <label for="edit-ex-sets">Series *</label>
                    <input type="number" id="edit-ex-sets" name="sets" min="1" max="20" required>
                </div>
                <div class="form-group">
                    <label for="edit-ex-reps">Repeticoes *</label>
                    <input type="text" id="edit-ex-reps" name="reps" required>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="edit-ex-weight">Carga</label>
                    <input type="text" id="edit-ex-weight" name="weight">
                </div>
                <div class="form-group">
                    <label for="edit-ex-rest">Descanso (seg)</label>
                    <input type="number" id="edit-ex-rest" name="restSeconds" min="0">
                </div>
            </div>
            <div class="form-group">
                <label for="edit-ex-notes">Notas</label>
                <textarea id="edit-ex-notes" name="notes" rows="2" placeholder="Dicas tecnicas..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modal-edit-exercise')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Salvar</button>
            </div>
        </form>
    </div>
</div>

<script>
const _csrf = document.querySelector('meta[name="csrf-token"]').content;

function openModal(id) {
    document.getElementById(id).classList.add('active');
    document.body.style.overflow = 'hidden';
}
function closeModal(id) {
    document.getElementById(id).classList.remove('active');
    document.body.style.overflow = '';
}
document.addEventListener('keydown', e => {
    if (e.key === 'Escape') document.querySelectorAll('.modal-backdrop.active').forEach(m => { m.classList.remove('active'); document.body.style.overflow = ''; });
});

function showToast(message, type = 'info') {
    let container = document.querySelector('.toast-container');
    if (!container) { container = document.createElement('div'); container.className = 'toast-container'; document.body.appendChild(container); }
    const toast = document.createElement('div');
    toast.className = 'toast toast-' + type;
    toast.textContent = message;
    container.appendChild(toast);
    requestAnimationFrame(() => toast.classList.add('show'));
    setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 400); }, 3500);
}

function esc(str) { return String(str || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'"); }

async function loadExercises(planId) {
    const container = document.getElementById('exercises-' + planId);
    try {
        const res = await fetch('/workouts/plans/' + planId + '/exercises');
        const data = await res.json();
        if (!data.success || data.exercises.length === 0) {
            container.innerHTML = '<p class="no-exercises-msg">Nenhum exercicio adicionado ainda</p>';
            return;
        }
        container.innerHTML = data.exercises.map(function(ex, i) {
            return '<div class="exercise-row" id="exercise-row-' + ex.id + '">' +
                '<div class="exercise-row-number">' + (i+1) + '</div>' +
                '<div class="exercise-row-info">' +
                    '<span class="exercise-row-name">' + ex.name + '</span>' +
                    '<div class="exercise-row-meta">' +
                        '<span class="meta-pill">' + ex.sets + 'x' + ex.reps + '</span>' +
                        (ex.weight ? '<span class="meta-pill">' + ex.weight + '</span>' : '') +
                        (ex.restSeconds ? '<span class="meta-pill">' + ex.restSeconds + 's</span>' : '') +
                        (ex.notes ? '<span class="meta-pill meta-notes">' + ex.notes + '</span>' : '') +
                    '</div>' +
                '</div>' +
                '<div class="exercise-row-actions">' +
                    '<button class="btn-icon" title="Editar" onclick="openEditExerciseModal(' + ex.id + ',' + planId + ',\'' + esc(ex.name) + '\',' + ex.sets + ',\'' + esc(ex.reps) + '\',\'' + esc(ex.weight||'') + '\',' + (ex.restSeconds||0) + ',\'' + esc(ex.notes||'') + '\')">' +
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>' +
                    '</button>' +
                    '<button class="btn-icon btn-icon-danger" title="Deletar" onclick="deleteExercise(' + ex.id + ',' + planId + ',\'' + esc(ex.name) + '\')">' +
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>' +
                    '</button>' +
                '</div>' +
            '</div>';
        }).join('');
    } catch (err) {
        container.innerHTML = '<p class="error-msg">Erro ao carregar exercicios</p>';
    }
}

async function updateExerciseCount(planId) {
    try {
        const res = await fetch('/workouts/plans/' + planId + '/exercises');
        const data = await res.json();
        const badge = document.getElementById('exercise-count-' + planId);
        if (badge && data.success) badge.textContent = data.exercises.length + ' exerc.';
    } catch(_) {}
}

function openCreatePlanModal() {
    document.getElementById('createPlanForm').reset();
    openModal('modal-create-plan');
    document.getElementById('create-plan-name').focus();
}

async function submitCreatePlan(e) {
    e.preventDefault();
    const fd = new FormData(e.target);
    const btn = document.getElementById('btn-create-plan');
    btn.disabled = true; btn.textContent = 'Criando...';
    try {
        const res = await fetch('/workouts/plans', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf }, body: JSON.stringify({ name: fd.get('name'), description: fd.get('description')||null, dayOfWeek: fd.get('dayOfWeek')||null }) });
        const data = await res.json();
        if (data.success) { showToast('Plano criado com sucesso!', 'success'); closeModal('modal-create-plan'); setTimeout(() => location.reload(), 1200); }
        else showToast(data.message || 'Erro ao criar plano', 'error');
    } catch(_) { showToast('Erro de conexao', 'error'); }
    finally { btn.disabled = false; btn.textContent = 'Criar Plano'; }
}

function openEditPlanModal(id, name, day, desc, isActive) {
    document.getElementById('edit-plan-id').value = id;
    document.getElementById('edit-plan-name').value = name;
    document.getElementById('edit-plan-day').value = day || '';
    document.getElementById('edit-plan-desc').value = desc || '';
    document.getElementById('edit-plan-active').checked = isActive;
    openModal('modal-edit-plan');
    document.getElementById('edit-plan-name').focus();
}

async function submitEditPlan(e) {
    e.preventDefault();
    const fd = new FormData(e.target);
    const planId = fd.get('planId');
    try {
        const res = await fetch('/workouts/plans/' + planId, { method: 'PUT', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf }, body: JSON.stringify({ name: fd.get('name'), description: fd.get('description')||null, dayOfWeek: fd.get('dayOfWeek')||null, isActive: fd.get('isActive') === 'true' }) });
        const data = await res.json();
        if (data.success) { showToast('Plano atualizado!', 'success'); closeModal('modal-edit-plan'); setTimeout(() => location.reload(), 1200); }
        else showToast(data.message || 'Erro ao atualizar', 'error');
    } catch(_) { showToast('Erro de conexao', 'error'); }
}

async function deletePlan(planId, planName) {
    if (!confirm('Deletar o plano "' + planName + '"?\n\nTodos os exercicios serao removidos.')) return;
    try {
        const res = await fetch('/workouts/plans/' + planId, { method: 'DELETE', headers: { 'X-CSRF-Token': _csrf } });
        const data = await res.json();
        if (data.success) { showToast('Plano deletado!', 'success'); setTimeout(() => location.reload(), 1000); }
        else showToast(data.message || 'Erro ao deletar', 'error');
    } catch(_) { showToast('Erro de conexao', 'error'); }
}

async function submitAddExercise(e, planId) {
    e.preventDefault();
    const form = e.target;
    const fd = new FormData(form);
    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    try {
        const res = await fetch('/workouts/plans/' + planId + '/exercises', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf }, body: JSON.stringify({ name: fd.get('name'), sets: fd.get('sets'), reps: fd.get('reps'), weight: fd.get('weight')||null, restSeconds: fd.get('restSeconds')||null, notes: fd.get('notes')||null }) });
        const data = await res.json();
        if (data.success) { showToast('Exercicio adicionado!', 'success'); form.reset(); form.closest('details').removeAttribute('open'); await loadExercises(planId); updateExerciseCount(planId); }
        else showToast(data.message || 'Erro ao adicionar', 'error');
    } catch(_) { showToast('Erro de conexao', 'error'); }
    finally { btn.disabled = false; }
}

function openEditExerciseModal(id, planId, name, sets, reps, weight, rest, notes) {
    document.getElementById('edit-ex-id').value = id;
    document.getElementById('edit-ex-plan-id').value = planId;
    document.getElementById('edit-ex-name').value = name;
    document.getElementById('edit-ex-sets').value = sets;
    document.getElementById('edit-ex-reps').value = reps;
    document.getElementById('edit-ex-weight').value = weight || '';
    document.getElementById('edit-ex-rest').value = rest || '';
    document.getElementById('edit-ex-notes').value = notes || '';
    openModal('modal-edit-exercise');
    document.getElementById('edit-ex-name').focus();
}

async function submitEditExercise(e) {
    e.preventDefault();
    const fd = new FormData(e.target);
    const exId = fd.get('exerciseId');
    const planId = fd.get('planId');
    try {
        const res = await fetch('/workouts/exercises/' + exId, { method: 'PUT', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf }, body: JSON.stringify({ name: fd.get('name'), sets: fd.get('sets'), reps: fd.get('reps'), weight: fd.get('weight')||null, restSeconds: fd.get('restSeconds')||null, notes: fd.get('notes')||null }) });
        const data = await res.json();
        if (data.success) { showToast('Exercicio atualizado!', 'success'); closeModal('modal-edit-exercise'); await loadExercises(planId); }
        else showToast(data.message || 'Erro ao atualizar', 'error');
    } catch(_) { showToast('Erro de conexao', 'error'); }
}

async function deleteExercise(exId, planId, name) {
    if (!confirm('Deletar o exercicio "' + name + '"?')) return;
    try {
        const res = await fetch('/workouts/exercises/' + exId, { method: 'DELETE', headers: { 'X-CSRF-Token': _csrf } });
        const data = await res.json();
        if (data.success) { showToast('Exercicio deletado!', 'success'); await loadExercises(planId); updateExerciseCount(planId); }
        else showToast(data.message || 'Erro ao deletar', 'error');
    } catch(_) { showToast('Erro de conexao', 'error'); }
}

document.addEventListener('DOMContentLoaded', function() {
    var planIds = <%- JSON.stringify(plans.map(function(p){ return p.id; })) %>;
    planIds.forEach(function(id) { loadExercises(id); });
});
</script>
