<div class="active-workout-page">
    <!-- Workout Header -->
    <div class="workout-header">
        <h1><%= session.workoutPlan.name %></h1>
        <a href="/workouts" class="btn-back">← Voltar</a>
    </div>

    <!-- Progress -->
    <div class="workout-controls">
        <div class="progress-bar-container">
            <div class="progress-label">
                <span id="progressText"><%= completedCount %>/<%= totalCount %> exercícios</span>
            </div>
            <div class="progress-bar">
                <div id="progressFill" class="progress-fill" style="width: <%= totalCount > 0 ? (completedCount / totalCount * 100) : 0 %>%"></div>
            </div>
        </div>
    </div>

    <!-- Exercises List -->
    <div class="exercises-list">
        <% session.sessionExercises.forEach((sessionExercise, index) => { %>
            <div class="exercise-item <%= sessionExercise.isCompleted ? 'completed' : '' %>"
                 data-exercise-id="<%= sessionExercise.id %>">
                
                <div class="exercise-header">
                    <div class="exercise-number">
                        <span class="number"><%= index + 1 %></span>
                    </div>
                    <div class="exercise-info">
                        <h3><%= sessionExercise.exercise.name %></h3>
                        <div class="exercise-meta">
                            <span class="meta-item">
                                <strong><%= sessionExercise.exercise.sets %>x<%= sessionExercise.exercise.reps %></strong>
                            </span>
                            <% if (sessionExercise.exercise.weight) { %>
                                <span class="meta-item">
                                    <strong><%= sessionExercise.exercise.weight %></strong>
                                </span>
                            <% } %>
                            <% if (sessionExercise.exercise.restSeconds) { %>
                                <span class="meta-item">
                                    🕐 <%= sessionExercise.exercise.restSeconds %>s descanso
                                </span>
                            <% } %>
                        </div>
                        <% if (sessionExercise.exercise.notes) { %>
                            <p class="exercise-notes"><%= sessionExercise.exercise.notes %></p>
                        <% } %>
                    </div>
                    <button class="btn-complete" data-session-id="<%= session.id %>" data-exercise-id="<%= sessionExercise.id %>">
                        <span class="check-icon">✓</span>
                        <span class="check-text">Concluído</span>
                    </button>
                </div>
            </div>
        <% }); %>
    </div>

    <!-- Complete Workout Button -->
    <div class="complete-section" style="display: none;" id="completeSection">
        <button id="completeWorkoutBtn" class="btn btn-success btn-lg">
            🏁 Finalizar Treino
        </button>
    </div>
</div>

<script>
    const sessionId = '<%= session.id %>';
    const csrfToken = '<%= csrfToken %>';
    const totalExercises = <%= totalCount %>;
    let completedCount = <%= completedCount %>;

    // Show complete button if already all done on load
    if (completedCount === totalExercises && totalExercises > 0) {
        document.getElementById('completeSection').style.display = 'block';
    }

    // Complete Exercise
    document.querySelectorAll('.btn-complete').forEach(btn => {
        // If already completed, disable button on load
        const exerciseItem = document.querySelector(`[data-exercise-id="${btn.dataset.exerciseId}"]`);
        if (exerciseItem && exerciseItem.classList.contains('completed')) {
            btn.disabled = true;
        }

        btn.addEventListener('click', async function() {
            const sessionId = this.dataset.sessionId;
            const exerciseId = this.dataset.exerciseId;
            const exerciseItem = document.querySelector(`[data-exercise-id="${exerciseId}"]`);

            try {
                this.disabled = true;

                const response = await fetch(`/workouts/session/${sessionId}/exercise/${exerciseId}/complete`, {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': csrfToken
                    }
                });

                if (!response.ok) throw new Error(`HTTP ${response.status}`);

                const data = await response.json();

                if (data.success) {
                    exerciseItem.classList.add('completed');
                    completedCount++;
                    document.getElementById('progressText').textContent = `${completedCount}/${totalExercises} exercícios`;
                    document.getElementById('progressFill').style.width = `${(completedCount / totalExercises) * 100}%`;

                    // Auto-finish when all exercises done
                    if (completedCount === totalExercises) {
                        showToast('Todos os exercícios concluídos! Finalizando treino... 🎉', 'success');
                        await finishWorkout();
                    } else {
                        showToast('Exercício concluído! ✓', 'success');
                    }
                } else {
                    throw new Error(data.message || 'Erro desconhecido');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Erro: ' + error.message, 'error');
                this.disabled = false;
            }
        });
    });

    async function finishWorkout() {
        try {
            const response = await fetch(`/workouts/session/${sessionId}/complete`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': csrfToken
                },
                body: JSON.stringify({ durationMin: 0 })
            });

            if (!response.ok) throw new Error(`HTTP ${response.status}`);

            const data = await response.json();

            if (data.success) {
                setTimeout(() => window.location.href = '/workouts', 1800);
            } else {
                throw new Error(data.message || 'Erro ao finalizar');
            }
        } catch (error) {
            console.error('Error:', error);
            showToast('Erro ao finalizar: ' + error.message, 'error');
            // Show manual button as fallback
            document.getElementById('completeSection').style.display = 'block';
        }
    }

    // Manual complete button (fallback)
    document.getElementById('completeWorkoutBtn')?.addEventListener('click', async function() {
        this.disabled = true;
        await finishWorkout();
    });
</script>
