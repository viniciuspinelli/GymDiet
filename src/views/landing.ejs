            <div class="lp-dashboard-mock">
                <div class="lp-mock-header">
                    <span class="lp-mock-dot" style="background:#ff5f57"></span>
                    <span class="lp-mock-dot" style="background:#febc2e"></span>
                    <span class="lp-mock-dot" style="background:#28c840"></span>
                    <span class="lp-mock-label">gymdiet.app — Meus Treinos</span>
                </div>
                <div class="lp-mock-body">
                    <div class="lp-mock-sidebar">
                        <div class="lp-mock-nav-item lp-mock-active">🏋️ Treinos</div>
                        <div class="lp-mock-nav-item">🥗 Dieta</div>
                        <div class="lp-mock-nav-item">🛒 Compras</div>
                    </div>
                    <div class="lp-mock-content">
